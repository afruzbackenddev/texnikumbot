async def check_sub(user_id):
    try:
        member = await bot.get_chat_member(CHANNEL, user_id)
        return member.status in ("member", "administrator", "creator")
    except:
        return False


async def send_blitz_question(chat_id, category):
    uid = chat_id
    available = questions if category == "all" else [q for q in questions if q["cat"] == category]
    q = random.choice(available)
    count = user_state[uid].get("quiz_count", 0) + 1
    text = f"🔟 Savol {count}/10\n\n❓ {q['q']}\n\n" + "\n".join(q['full_options'])
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text=opt, callback_data=f"ans_{opt}_{q['answer']}_{q['cat']}")] for opt in ["A", "B", "C"]
    ])
    await bot.send_message(chat_id, text, reply_markup=kb)



