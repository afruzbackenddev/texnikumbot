@dp.callback_query(lambda c: c.data.startswith("ans_"))
async def check_answer(callback: CallbackQuery):
    data = callback.data.split("_")
    user_ans = data[1]
    correct_ans = data[2]
    cat = data[3]
    uid = callback.from_user.id

    if user_ans == correct_ans:
        user_state[uid]["score"] += 1
        user_state[uid]["current_quiz_score"] += 1
        user_state[uid]["by_cat"][cat] = user_state[uid]["by_cat"].get(cat, 0) + 1
        await callback.answer("✅ To'g'ri!")
    else:
        await callback.answer(f"❌ Noto'g'ri! Javob: {correct_ans}", show_alert=True)

    user_state[uid]["total"] += 1
    user_state[uid]["quiz_count"] += 1
    await callback.message.delete()


    if user_state[uid]["quiz_count"] >= 10:
        score = user_state[uid]["current_quiz_score"]
        await callback.message.answer(
            f"🏁 **Test yakunlandi!**\n\nSiz 10 ta savoldan **{score}** tasiga to'g'ri javob berdingiz.",
            reply_markup=menu)
        user_state[uid]["quiz_count"] = 0
    else:
        await send_blitz_question(callback.message.chat.id, user_state[uid]["last_cat"])


